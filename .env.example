# =============================================================================
# Self-Sovereign Identity — Root .env.example
# Copy to .env and fill in real values for the subsystem you intend to run.
# Each subsystem also has its own .env.example.
# =============================================================================

# ---------- Stellar / Soroban ---------------------------------------------
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_IDENTITY_CONTRACT=
STELLAR_WRAPPED_BADGE_CONTRACT=
STELLAR_DEPLOYER_SECRET=

# ---------- EVM (Ethereum / Polygon / Arbitrum) ----------------------------
EVM_RPC_URL=http://localhost:8545
EVM_CHAIN_ID=31337
# Replace with a freshly generated key for your deployment. NEVER commit a real key.
EVM_DEPLOYER_PRIVATE_KEY=
EVM_REGISTRY_CONTRACT=
EVM_BADGE_CONTRACT=
EVM_BRIDGE_CONTRACT=

# ---------- Zero-Knowledge Proofs -----------------------------------------
ZKEY_PATH=./packages/zk-circuits/keys/credential.zkey
WASM_PATH=./packages/zk-circuits/build/credential_js/credential.wasm

# ---------- IPFS / off-chain storage --------------------------------------
IPFS_API_URL=http://localhost:5001
IPFS_GATEWAY_URL=http://localhost:8081
IPFS_ENCRYPTION_KEY=replace-with-32-byte-base64-key

# ---------- Bridge relayer ------------------------------------------------
RELAYER_PRIVATE_KEY=
RELAYER_FEE_BPS=30

# ---------- AI fraud detection --------------------------------------------
AI_FRAUD_URL=http://localhost:8000
AI_FRAUD_THRESHOLD=0.85

# ---------- API gateway ---------------------------------------------------
API_GATEWAY_PORT=8080
DATABASE_URL=postgres://ssi:ssi_dev@localhost:5432/ssi
REDIS_URL=redis://localhost:6379
JWT_SECRET=replace-with-strong-random-string

# ---------- Frontend -----------------------------------------------------
VITE_API_URL=http://localhost:8080
VITE_STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
VITE_BRIDGE_RELAYER_WS=ws://localhost:8081
