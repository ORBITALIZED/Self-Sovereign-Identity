{
  "name": "@ssi/service-bridge-relayer",
  "version": "0.1.0",
  "description": "Cross-chain relayer that watches Stellar + EVM and mints wrapped identity badges on Soroban.",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "^12.0.0",
    "@ssi/sdk": "workspace:*",
    "eventemitter3": "^5.0.1",
    "ioredis": "^5.3.2",
    "pg": "^8.11.5",
    "viem": "^2.21.0",
    "pino": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/pg": "^8.11.4",
    "tsx": "^4.7.0",
    "typescript": "^5.4.5",
    "vitest": "^4.1.10"
  }
}
